{
  "manifest_version": 3,
  "name": "WA Copilot — Sync Contacts",
  "short_name": "WA Copilot",
  "version": "1.0.4",
  "description": "Syncs your WhatsApp contact names into the WA Copilot desktop app so your brokers appear by name instead of phone number.",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WA Copilot — Sync Contacts",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
